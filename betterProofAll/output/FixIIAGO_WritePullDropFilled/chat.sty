\title{The Burden of Proof: Automated Tooling for Rapid Iteration on Large Mechanised Proofs}

\author{
\IEEEauthorblockN{Chengsong Tan\IEEEauthorrefmark{1}\IEEEauthorrefmark{2}, Alastair F. Donaldson\IEEEauthorrefmark{1}, Jonathan Juli\'an Huerta y Munive\IEEEauthorrefmark{3}, and John Wickerson\IEEEauthorrefmark{1}}
