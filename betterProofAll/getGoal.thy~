fun get_text_after_pos p t = Position.id_of p t

(*using a "finite state machine" to record which error mode the cursor is currently at *)
fun extract_and_fix_texts [] fixcount _ = ""
  | extract_and_fix_texts ((_, (ac,st,err)) :: rest) fixcount NONE = 
   (case err of NONE => (Actions.text_of (ac)) ^ extract_and_fix_texts rest fixcount NONE | 
                SOME (exn, _) => 
      (if is_refine (ac,exn)  then 
        let val (acnew, stnew, ernew) = fix_refine_goal  st ac in
          Actions.text_of acnew ^ extract_and_fix_texts rest 1 (SOME (acnew, stnew, ernew)) end 
      else if is_proof (ac, exn) then
        (let val thy = Toplevel.theory_of st;
          val acnew1 = Actions.make_one thy ("sorry");
          val (stnew1, ernew1) = Actions.apply_safe acnew1 st in ("sorry" ^extract_and_fix_texts rest 2 (SOME (acnew1, stnew1, ernew1))) 
        end)  
      else (Actions.text_of (ac)) ^ extract_and_fix_texts rest fixcount NONE))
(*the trace has been changed to the new state, old text still needed for processing*)
  | extract_and_fix_texts ((_, (ac, st, err)) :: rest) fixcount (SOME (acnew, stnew, ernew)) = 
(*simplifying assumption: if no errors in old state, then new state is in sync with good bits of old state
and we can safely continue using old text *)
    (case err of NONE => (let val thy = Toplevel.theory_of stnew;
      val good_old_action_text = Actions.text_of (ac)
      val acnew1 = Actions.make_one thy (good_old_action_text);
      val (stnew1, ernew1) = Actions.apply_safe acnew1 stnew in (good_old_action_text ^ extract_and_fix_texts rest fixcount (SOME (acnew1, stnew1, ernew1))) 
        end) 
     |               SOME (exn,s)  => 
      if fixcount = 1 then
        (let val thy = Toplevel.theory_of stnew;
          val acnew1 = Actions.make_one thy ("sorry");
          val (stnew1, ernew1) = Actions.apply_safe acnew1 stnew in ("sorry" ^extract_and_fix_texts rest 0 (SOME (acnew1, stnew1, ernew1))) 
        end) 
      else (*fixcount = 2, proof error, should have been fixed. *)
        (let val thy = Toplevel.theory_of stnew;
            val good_old_action_text = Actions.text_of (ac);
            val acnew1 = Actions.make_one thy (good_old_action_text);
            val (stnew1, ernew1) = Actions.apply_safe acnew1 stnew 
         in (good_old_action_text ^ extract_and_fix_texts rest 0 (SOME (acnew, stnew, ernew))) 
        end))
