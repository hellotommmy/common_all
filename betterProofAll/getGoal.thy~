fun extract_texts [] fixcount = ""
  | extract_texts ((_, (ac,st,err)) :: rest) fixcount = 
   ( case err of NONE => (Actions.text_of (ac)) ^ extract_texts rest fixcount | 
                  _  => (if fixcount > 0 then 
      let val (acnew, stnew, errnew) = fix_refine_goal  st ac in
        Actions.text_of acnew ^ extract_texts rest (fixcount-1) end 
      else (Actions.text_of (ac)) ^ extract_texts rest fixcount))

